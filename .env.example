# Multi-Agent Debate System Environment Variables

# ========================================
# AWS Bedrock Configuration
# ========================================

# Option 1: Direct AWS Credentials (Not recommended for production)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Option 2: AWS Profile (Recommended)
# AWS_PROFILE=your_profile_name

# Option 3: Okta-based Authentication (Recommended for enterprises)
# When using okta-aws-cli, credentials are automatically set in environment
# Just run: okta-aws-cli -p sandbox
# No need to set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY manually
# The session credentials (AWS_SESSION_TOKEN) will be set automatically

# AWS Region
AWS_REGION=us-east-1

# Bedrock Model ID
# IMPORTANT: Use on-demand compatible models or inference profile ARNs

# Option 1: Direct Model IDs (on-demand compatible - RECOMMENDED)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Alternative direct model IDs:
# BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0    # Faster, cheaper
# BEDROCK_MODEL_ID=anthropic.claude-3-opus-20240229-v1:0     # Highest quality

# Option 2: Inference Profile ARNs (for newer models like Claude 3.5+)
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20240620-v1:0
# BEDROCK_MODEL_ID=eu.anthropic.claude-3-5-sonnet-20240620-v1:0  # For EU regions

# Note: Some models require inference profiles and won't work with direct invocation.
# If you see \"ValidationException\" errors, use one of the models listed above.

# ========================================
# Tavily Search API
# ========================================

# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Note: If not provided, the system will use mock search data

# ========================================
# S3 Image Ingestion (for Streamlit image uploads)
# ========================================

# Primary bucket variable used by the app
S3_IMAGE_BUCKET_NAME=your-debate-image-bucket

# Optional key prefix for uploads
S3_IMAGE_PREFIX=debate-images

# Emergency workaround for environments with SSL interception / broken CA trust.
# Set to true only if S3 requests fail with CERTIFICATE_VERIFY_FAILED.
S3_DISABLE_SSL_VERIFICATION=false

# Backward compatibility alias (optional)
# S3_BUCKET_NAME=your-debate-image-bucket

# ========================================
# Debate Configuration (Optional)
# ========================================

# Default number of debate rounds
# DEFAULT_ROUNDS=2

# Maximum tokens for LLM responses
# MAX_TOKENS=4096

# Temperature for response generation (0.0 - 1.0)
# TEMPERATURE=0.7
